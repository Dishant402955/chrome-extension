{
  "manifest_version": 3,
  "name": "Recorder",
  "version": "7.0",
  "action": { "default_title": "Open Recorder" },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "downloads",
    "windows"
  ],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["content.js"] }
  ]
}